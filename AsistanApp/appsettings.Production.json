{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning",
      "System": "Warning"
    },
    "ApplicationInsights": {
      "LogLevel": {
        "Default": "Information"
      }
    }
  },
  "ConnectionStrings": {
    "VitaGuardDb": "Server=vitaguard-prod.database.windows.net,1433;Initial Catalog=VitaGuardDb;Persist Security Info=False;User ID=vitaguard_admin;Password=YOUR_SECURE_PASSWORD;Encrypt=True;TrustServerCertificate=False;Connection Timeout=30;",
    "DefaultConnection": "Server=vitaguard-prod.database.windows.net;Database=VitaGuardDb;User Id=vitaguard_admin;Password=YOUR_SECURE_PASSWORD;TrustServerCertificate=false;"
  },
  "AllowedHosts": "*.vitaguard.app,vitaguard.app,api.vitaguard.app,family.vitaguard.app",
  
  "EmergencyResponse": {
    "ConfirmationDelaySeconds": 8,
    "MaxDelaySeconds": 30,
    "MinDelaySeconds": 2,
    "AllowUserCustomization": true,
    "EnableAutoEscalation": true,
    "EscalationDelaySeconds": 60
  },
  
  "ApplicationInsights": {
    "InstrumentationKey": "YOUR_INSTRUMENTATION_KEY_HERE"
  },
  "Kestrel": {
    "Endpoints": {
      "Http": {
        "Url": "http://0.0.0.0:80"
      },
      "Https": {
        "Url": "https://0.0.0.0:443",
        "Certificate": {
          "Path": "/etc/ssl/certs/vitaguard.pfx",
          "Password": "YOUR_CERT_PASSWORD"
        }
      }
    }
  },
  "Jwt": {
    "SecretKey": "YOUR_SUPER_SECRET_JWT_KEY_CHANGE_THIS_IN_PRODUCTION",
    "ExpirationMinutes": 1440,
    "Issuer": "vitaguard.app",
    "Audience": "vitaguard-users"
  },
  "SignalR": {
    "KeepAliveInterval": 15000,
    "ClientTimeoutInterval": 30000,
    "MaximumReceiveMessageSize": 32768
  },
  "Cors": {
    "AllowedOrigins": [
      "https://vitaguard.app",
      "https://www.vitaguard.app",
      "https://family.vitaguard.app",
      "https://api.vitaguard.app"
    ],
    "AllowedMethods": [ "GET", "POST", "PUT", "DELETE", "OPTIONS" ],
    "AllowedHeaders": [ "Content-Type", "Authorization" ],
    "AllowCredentials": true
  },
  "RateLimiting": {
    "Enabled": true,
    "RequestsPerMinute": 100,
    "BurstLimit": 150,
    "WindowSeconds": 60
  },
  "Features": {
    "EnableSwagger": false,
    "EnableDetailedLogging": false,
    "EnableHealthChecks": true,
    "MaxLoginAttempts": 5,
    "LockoutDurationMinutes": 15,
    "PasswordExpirationDays": 90
  },
  "Email": {
    "SmtpServer": "smtp.outlook.com",
    "SmtpPort": 587,
    "FromAddress": "noreply@vitaguard.app",
    "FromName": "VitaGuard",
    "UseStartTls": true,
    "TimeoutSeconds": 10
  },
  "Sms": {
    "Provider": "twilio",
    "FromNumber": "",
    "EmergencyServicesNumber": "",
    "Twilio": {
      "AccountSid": "",
      "AuthToken": ""
    }
  },
  "Localization": {
    "DefaultCulture": "tr-TR",
    "SupportedCultures": [ "tr-TR", "en-US", "de-DE" ]
  },
  "ErrorHandling": {
    "EnableDetailedErrors": false,
    "LogStackTraces": false,
    "SendErrorEmails": true,
    "ErrorEmailRecipients": [ "admin@vitaguard.app", "support@vitaguard.app" ]
  },
  "DataProtection": {
    "EnableEncryption": true,
    "KeyStoragePath": "/var/lib/vitaguard/keys",
    "RotationSchedule": "monthly"
  }
}
