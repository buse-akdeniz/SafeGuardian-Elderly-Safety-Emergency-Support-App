{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning",
      "System": "Warning"
    },
    "ApplicationInsights": {
      "LogLevel": {
        "Default": "Information"
      }
    }
  },
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=/var/lib/vitaguard/asistanapp-prod.db"
  },
  "AllowedHosts": "*",
  "App": {
    "PublicBaseUrl": "https://safeguardian-elderly-safety-emergency-support-ap-production.up.railway.app"
  },
  
  "EmergencyResponse": {
    "ConfirmationDelaySeconds": 8,
    "MaxDelaySeconds": 30,
    "MinDelaySeconds": 2,
    "AllowUserCustomization": true,
    "EnableAutoEscalation": true,
    "EscalationDelaySeconds": 60
  },
  
  "ApplicationInsights": {
    "InstrumentationKey": "YOUR_INSTRUMENTATION_KEY_HERE"
  },
  "Jwt": {
    "SecretKey": "",
    "Issuer": "safeguardian.app",
    "Audience": "safeguardian-mobile",
    "AccessTokenMinutes": 15,
    "RefreshTokenDays": 30
  },
  "SeedData": {
    "Enabled": false
  },
  "FamilyPortal": {
    "SharedPassword": "123"
  },
  "Subscriptions": {
    "AppleSharedSecret": "",
    "AppStoreServerApiKey": ""
  },
  "RevenueCat": {
    "WebhookAuthKey": "",
    "IosPublicSdkKey": "",
    "AndroidPublicSdkKey": ""
  },
  "AdMob": {
    "RewardedAdUnitIds": [
      "ca-app-pub-8847006171122424/6344435151"
    ]
  },
  "SignalR": {
    "KeepAliveInterval": 15000,
    "ClientTimeoutInterval": 30000,
    "MaximumReceiveMessageSize": 32768
  },
  "Cors": {
    "AllowedOrigins": [
      "https://safeguardian-elderly-safety-emergency-support-ap-production.up.railway.app",
      "capacitor://localhost"
    ],
    "AllowedMethods": [ "GET", "POST", "PUT", "DELETE", "OPTIONS" ],
    "AllowedHeaders": [ "Content-Type", "Authorization" ],
    "AllowCredentials": true
  },
  "RateLimiting": {
    "Enabled": true,
    "RequestsPerMinute": 100,
    "BurstLimit": 150,
    "WindowSeconds": 60
  },
  "Features": {
    "EnableSwagger": false,
    "EnableDetailedLogging": false,
    "EnableHealthChecks": true,
    "MaxLoginAttempts": 5,
    "LockoutDurationMinutes": 15,
    "PasswordExpirationDays": 90
  },
  "Email": {
    "SmtpServer": "smtp.outlook.com",
    "SmtpPort": 587,
    "FromAddress": "noreply@vitaguard.app",
    "FromName": "VitaGuard",
    "Username": "",
    "Password": "",
    "UseStartTls": true,
    "TimeoutSeconds": 10
  },
  "Sms": {
    "Provider": "twilio",
    "FromNumber": "",
    "EmergencyServicesNumber": "",
    "DailyPerUserLimit": 10,
    "Twilio": {
      "AccountSid": "",
      "AuthToken": ""
    }
  },
  "Localization": {
    "DefaultCulture": "tr-TR",
    "SupportedCultures": [ "tr-TR", "en-US", "de-DE" ]
  },
  "ErrorHandling": {
    "EnableDetailedErrors": false,
    "LogStackTraces": false,
    "SendErrorEmails": true,
    "ErrorEmailRecipients": [ "admin@vitaguard.app", "support@vitaguard.app" ]
  },
  "DataProtection": {
    "EnableEncryption": true,
    "KeyStoragePath": "/var/lib/vitaguard/keys",
    "RotationSchedule": "monthly"
  }
}
