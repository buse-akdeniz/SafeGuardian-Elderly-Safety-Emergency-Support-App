{
  "name": "safeguardian-asistanapp",
  "version": "2.0.0",
  "private": true,
  "description": "SafeGuardian AsistanApp - Capacitor wrapper",
  "scripts": {
    "postinstall": "node tools/patch-admob-consent-swift.js",
    "cap:add:ios": "npx cap add ios",
    "cap:add:android": "npx cap add android",
    "cap:sync": "npx cap sync",
    "cap:sync:android": "npx cap sync android",
    "cap:open:ios": "npx cap open ios",
    "cap:open:android": "npx cap open android",
    "android:bundle": "npm run cap:sync:android && cd android && ./gradlew bundleRelease",
    "cap:run:ios": "open -a Simulator && npx cap run ios",
    "cap:copy:watch": "chokidar 'wwwroot/**/*' -c 'npx cap copy ios' --initial=false"
  },
  "dependencies": {
    "@aparajita/capacitor-biometric-auth": "^8.0.2",
    "@capacitor-community/admob": "^6.1.0",
    "@capacitor/android": "^6.2.1",
    "@capacitor/camera": "^6.1.3",
    "@capacitor/core": "^6.0.0",
    "@capacitor/geolocation": "^6.1.1",
    "@capacitor/ios": "^6.0.0",
    "@capacitor/preferences": "^6.0.4",
    "@revenuecat/purchases-capacitor": "^9.2.2"
  },
  "devDependencies": {
    "@capacitor/cli": "^6.0.0",
    "chokidar-cli": "^3.0.0"
  }
}
